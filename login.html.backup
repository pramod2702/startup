<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VICTNOW - Luxury Fragrance Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 25%, #2d2d2d 50%, #1a1a1a 75%, #0a0a0a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* Animated Background */
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 30%, rgba(212, 175, 55, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 50% 50%, rgba(244, 228, 188, 0.05) 0%, transparent 70%);
            animation: backgroundFloat 10s ease-in-out infinite;
        }

        @keyframes backgroundFloat {
            0%, 100% { transform: translateY(0px) scale(1); }
            25% { transform: translateY(-30px) scale(1.05); }
            50% { transform: translateY(-15px) scale(1.02); }
            75% { transform: translateY(-25px) scale(1.03); }
        }

        /* Floating Particles */
        .particles {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(212, 175, 55, 0.6);
            border-radius: 50%;
            animation: float 15s infinite linear;
        }

        .particle:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 20s; }
        .particle:nth-child(2) { left: 20%; animation-delay: 2s; animation-duration: 18s; }
        .particle:nth-child(3) { left: 30%; animation-delay: 4s; animation-duration: 22s; }
        .particle:nth-child(4) { left: 40%; animation-delay: 6s; animation-duration: 19s; }
        .particle:nth-child(5) { left: 50%; animation-delay: 8s; animation-duration: 21s; }
        .particle:nth-child(6) { left: 60%; animation-delay: 10s; animation-duration: 17s; }
        .particle:nth-child(7) { left: 70%; animation-delay: 12s; animation-duration: 23s; }
        .particle:nth-child(8) { left: 80%; animation-delay: 14s; animation-duration: 20s; }
        .particle:nth-child(9) { left: 90%; animation-delay: 16s; animation-duration: 18s; }

        @keyframes float {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100vh) rotate(720deg);
                opacity: 0;
            }
        }

        /* Main Container */
        .auth-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 480px;
            padding: 20px;
        }

        .auth-container {
            background: linear-gradient(145deg, rgba(20, 20, 20, 0.95), rgba(10, 10, 10, 0.9));
            backdrop-filter: blur(20px);
            border: 2px solid transparent;
            border-image: linear-gradient(135deg, #d4af37, #f4e4bc, #d4af37) 1;
            border-radius: 25px;
            padding: 50px 40px;
            box-shadow: 
                0 25px 50px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(212, 175, 55, 0.3),
                0 0 30px rgba(212, 175, 55, 0.1),
                inset 0 2px 0 rgba(255, 255, 255, 0.1);
            text-align: center;
            position: relative;
            overflow: hidden;
            transform: perspective(1000px) rotateX(1deg);
            transition: all 0.4s ease;
        }

        .auth-container:hover {
            transform: perspective(1000px) rotateX(0deg) translateY(-5px);
            box-shadow: 
                0 35px 70px rgba(0, 0, 0, 0.6),
                0 0 0 2px rgba(212, 175, 55, 0.4),
                0 0 40px rgba(212, 175, 55, 0.2),
                inset 0 2px 0 rgba(255, 255, 255, 0.15);
        }
        
        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #d4af37, transparent);
            animation: shimmer 3s ease-in-out infinite;
        }
        
        @keyframes shimmer {
            0%, 100% { transform: translateX(-100%); }
            50% { transform: translateX(100%); }
        }
        
        .logo-section {
            margin-bottom: 40px;
            position: relative;
        }
        
        .logo {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #d4af37, #f4e4bc, #d4af37, #b8941f);
            background-size: 300% 300%;
            animation: gradientShift 6s ease-in-out infinite;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            box-shadow: 
                0 20px 40px rgba(212, 175, 55, 0.5),
                0 0 0 4px rgba(212, 175, 55, 0.3),
                0 0 20px rgba(212, 175, 55, 0.2),
                inset 0 3px 0 rgba(255, 255, 255, 0.4);
            position: relative;
            transform: scale(1);
            transition: all 0.4s ease;
        }
        
        .logo:hover {
            transform: scale(1.1) rotate(5deg);
            box-shadow: 
                0 25px 50px rgba(212, 175, 55, 0.6),
                0 0 0 5px rgba(212, 175, 55, 0.4),
                0 0 30px rgba(212, 175, 55, 0.3),
                inset 0 3px 0 rgba(255, 255, 255, 0.5);
        }
        
        @keyframes gradientShift {
            0%, 100% { background-position: 0% 50%; }
            25% { background-position: 50% 25%; }
            50% { background-position: 100% 50%; }
            75% { background-position: 50% 75%; }
        }
        
        .logo::before {
            content: '';
            position: absolute;
            top: -5px;
            left: -5px;
            right: -5px;
            bottom: -5px;
            background: linear-gradient(45deg, #d4af37, #f4e4bc, #d4af37, #b8941f);
            background-size: 200% 200%;
            animation: rotateGradient 3s linear infinite;
            border-radius: 50%;
            z-index: -1;
            opacity: 0.7;
        }
        
        @keyframes rotateGradient {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        .logo::after {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            border-radius: 50%;
            z-index: -1;
            animation: shimmer 2s ease-in-out infinite;
        }
        
        @keyframes shimmer {
            0%, 100% { opacity: 0; }
            50% { opacity: 1; }
        }
        
        .logo i {
            color: #0a2e0a;
            font-size: 2.2rem;
            font-weight: bold;
            animation: iconFloat 4s ease-in-out infinite;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }
        
        @keyframes iconFloat {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            25% { transform: translateY(-2px) rotate(2deg); }
            50% { transform: translateY(-4px) rotate(0deg); }
            75% { transform: translateY(-2px) rotate(-2deg); }
        }
        
        h1 {
            color: #d4af37;
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 4px;
            background: linear-gradient(135deg, #d4af37, #f4e4bc, #d4af37);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: textGradient 4s ease-in-out infinite;
            text-shadow: 0 4px 8px rgba(212, 175, 55, 0.3);
        }
        
        @keyframes textGradient {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }
        
        .tagline {
            color: rgba(255, 255, 255, 0.8);
            font-size: 1rem;
            margin-bottom: 45px;
            font-weight: 400;
            letter-spacing: 2px;
            text-transform: uppercase;
            opacity: 0;
            animation: fadeInUp 1s ease forwards 0.5s;
        }
        
        @keyframes fadeInUp {
            from { 
                opacity: 0;
                transform: translateY(20px);
            }
            to { 
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .form-group {
            margin-bottom: 30px;
            text-align: left;
            position: relative;
            opacity: 0;
            animation: fadeInUp 0.6s ease forwards;
        }
        
        .form-group:nth-child(1) { animation-delay: 0.1s; }
        .form-group:nth-child(2) { animation-delay: 0.2s; }
        
        .form-group label {
            display: block;
            color: #d4af37;
            font-weight: 700;
            margin-bottom: 12px;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 2px 4px rgba(212, 175, 55, 0.3);
        }
        
        .input-wrapper {
            position: relative;
        }
        
        .input-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(212, 175, 55, 0.05));
            border-radius: 15px;
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: 0;
        }
        
        .input-wrapper:hover::before {
            opacity: 1;
        }
        
        .input-wrapper i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #d4af37;
            font-size: 1.2rem;
            z-index: 3;
            transition: all 0.4s ease;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }
        
        .form-group input {
            width: 100%;
            padding: 20px 18px 20px 50px;
            border: 2px solid rgba(212, 175, 55, 0.3);
            background: linear-gradient(135deg, rgba(10, 46, 10, 0.2), rgba(10, 46, 10, 0.1));
            color: white;
            border-radius: 15px;
            font-size: 16px;
            font-weight: 500;
            box-sizing: border-box;
            transition: all 0.4s ease;
            position: relative;
            z-index: 2;
            backdrop-filter: blur(10px);
        }
        
        .form-group input:focus {
            outline: none;
            border-color: #d4af37;
            background: linear-gradient(135deg, rgba(10, 46, 10, 0.3), rgba(10, 46, 10, 0.2));
            box-shadow: 
                0 0 25px rgba(212, 175, 55, 0.4),
                0 0 0 4px rgba(212, 175, 55, 0.2),
                inset 0 2px 0 rgba(255, 255, 255, 0.1);
            transform: translateY(-3px) scale(1.02);
        }
        
        .form-group input:focus + i {
            color: #f4e4bc;
            transform: translateY(-50%) scale(1.2) rotate(5deg);
            text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
        }
        
        .form-group input::placeholder {
            color: rgba(255, 255, 255, 0.5);
            font-style: italic;
            font-weight: 400;
        }
        
        .form-group input:hover {
            border-color: rgba(212, 175, 55, 0.5);
            transform: translateY(-1px);
        }
        
        .login-btn {
            width: 100%;
            background: linear-gradient(135deg, #d4af37, #f4e4bc, #d4af37, #b8941f);
            background-size: 300% 300%;
            color: #0a2e0a;
            border: none;
            padding: 22px;
            border-radius: 18px;
            font-size: 1.2rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 3px;
            cursor: pointer;
            transition: all 0.4s ease;
            box-shadow: 
                0 15px 35px rgba(212, 175, 55, 0.5),
                0 0 0 3px rgba(212, 175, 55, 0.3),
                0 0 20px rgba(212, 175, 55, 0.2),
                inset 0 2px 0 rgba(255, 255, 255, 0.3);
            margin-top: 35px;
            position: relative;
            overflow: hidden;
            animation: btnGradient 4s ease-in-out infinite;
        }
        
        @keyframes btnGradient {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }
        
        .login-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
            transition: left 0.6s ease;
        }
        
        .login-btn::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.3), transparent);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: all 0.6s ease;
        }
        
        .login-btn:hover::before {
            left: 100%;
        }
        
        .login-btn:hover::after {
            width: 300px;
            height: 300px;
        }
        
        .login-btn:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 
                0 20px 50px rgba(212, 175, 55, 0.6),
                0 0 0 4px rgba(212, 175, 55, 0.4),
                0 0 30px rgba(212, 175, 55, 0.3),
                inset 0 2px 0 rgba(255, 255, 255, 0.4);
        }
        
        .login-btn:active {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 
                0 10px 30px rgba(212, 175, 55, 0.5),
                0 0 0 3px rgba(212, 175, 55, 0.3),
                inset 0 2px 0 rgba(255, 255, 255, 0.2);
        }
        
        .forgot-password {
            display: inline-block;
            color: #d4af37;
            text-decoration: none;
            font-size: 0.9rem;
            margin-top: 20px;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .forgot-password::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: #d4af37;
            transition: width 0.3s ease;
        }
        
        .forgot-password:hover::after {
            width: 100%;
        }
        
        .forgot-password:hover {
            color: #f4e4bc;
            text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
        }
        
        .message {
            background: rgba(212, 175, 55, 0.1);
            border: 1px solid rgba(212, 175, 55, 0.3);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 25px;
            text-align: center;
            display: none;
            font-size: 0.9rem;
        }
        
        .message.error {
            background: rgba(220, 53, 69, 0.1);
            border-color: rgba(220, 53, 69, 0.3);
            color: #ff6b6b;
        }
        
        .message.success {
            background: rgba(40, 167, 69, 0.1);
            border-color: rgba(40, 167, 69, 0.3);
            color: #51cf66;
        }
        
        .message.show {
            display: block;
            animation: slideDown 0.3s ease;
        }
        
        @keyframes slideDown {
            from { 
                opacity: 0;
                transform: translateY(-10px);
            }
            to { 
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        /* Tab Navigation Styles */
        .tab-navigation {
            display: flex;
            background: rgba(212, 175, 55, 0.1);
            border-radius: 15px;
            padding: 4px;
            margin-bottom: 30px;
            position: relative;
        }
        
        .tab-btn {
            flex: 1;
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.7);
            padding: 15px 20px;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            position: relative;
            z-index: 2;
        }
        
        .tab-btn i {
            font-size: 1rem;
        }
        
        .tab-btn.active {
            background: linear-gradient(135deg, #d4af37, #b8941f);
            color: #0a2e0a;
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
            transform: translateY(-1px);
        }
        
        .tab-btn:hover:not(.active) {
            color: #d4af37;
            background: rgba(212, 175, 55, 0.1);
        }
        
        /* Form Styles */
        .auth-form {
            display: none;
            animation: fadeIn 0.3s ease;
        }
        
        .auth-form.active {
            display: block;
        }
        
        @keyframes fadeIn {
            from { 
                opacity: 0;
                transform: translateY(10px);
            }
            to { 
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .register-btn {
            width: 100%;
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
            border: none;
            padding: 20px;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 
                0 10px 30px rgba(40, 167, 69, 0.4),
                0 0 0 2px rgba(40, 167, 69, 0.2);
            margin-top: 30px;
            position: relative;
            overflow: hidden;
        }
        
        .register-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s ease;
        }
        
        .register-btn:hover::before {
            left: 100%;
        }
        
        .register-btn:hover {
            transform: translateY(-3px);
            box-shadow: 
                0 15px 40px rgba(40, 167, 69, 0.5),
                0 0 0 3px rgba(40, 167, 69, 0.3);
            background: linear-gradient(135deg, #34ce57, #26d0ce);
        }
        
        .register-btn:active {
            transform: translateY(-1px);
        }
        
        /* New User Section Styles */
        .new-user-section {
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid rgba(212, 175, 55, 0.2);
        }
        
        .new-user-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            text-align: center;
            margin: 0;
        }
        
        .register-link {
            color: #d4af37;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .register-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: #d4af37;
            transition: width 0.3s ease;
        }
        
        .register-link:hover::after {
            width: 100%;
        }
        
        .register-link:hover {
            color: #f4e4bc;
            text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
        }
        
        /* Back to Login Section */
        .back-to-login {
            margin-top: 20px;
            text-align: center;
        }
        
        .back-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            margin: 0;
        }
        
        .back-link {
            color: #28a745;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .back-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: #28a745;
            transition: width 0.3s ease;
        }
        
        .back-link:hover::after {
            width: 100%;
        }
        
        .back-link:hover {
            color: #34ce57;
            text-shadow: 0 0 10px rgba(40, 167, 69, 0.5);
        }
        
        /* Demo Credentials Section */
        .demo-credentials {
            margin: 20px 0;
            padding: 15px;
            background: rgba(212, 175, 55, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 10px;
        }
        
        .demo-title {
            color: #d4af37;
            font-size: 0.85rem;
            font-weight: 600;
            margin: 0 0 10px 0;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .credential-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        
        .credential-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 12px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 6px;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
        }
        
        .credential-item:hover {
            background: rgba(212, 175, 55, 0.1);
            transform: translateX(3px);
        }
        
        .cred-user {
            color: #d4af37;
            font-weight: 600;
            font-family: 'Courier New', monospace;
        }
        
        .cred-pass {
            color: #f4e4bc;
            font-weight: 600;
            font-family: 'Courier New', monospace;
        }
        
        .credential-item small {
            color: rgba(255, 255, 255, 0.6);
            font-style: italic;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-container">
            <div class="logo-section">
                <div class="logo">
                    <i class="fas fa-crown"></i>
                </div>
                <h1>VICTNOW</h1>
                <p class="tagline">The Fragrance of Leadership</p>
            </div>
            
            <!-- Tab Navigation -->
            <div class="tab-navigation">
                <button class="tab-btn active" onclick="switchTab('login')" id="loginTab">
                    <i class="fas fa-sign-in-alt"></i>
                    Existing User
                </button>
                <button class="tab-btn" onclick="switchTab('register')" id="registerTab">
                    <i class="fas fa-user-plus"></i>
                    New User
                </button>
            </div>
            
            <div class="message" id="message"></div>
            
            <!-- Login Form -->
            <form id="loginForm" class="auth-form active" onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label for="username">Username</label>
                    <div class="input-wrapper">
                        <input type="text" id="username" name="username" placeholder="Enter your username" required>
                        <i class="fas fa-user"></i>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="password" name="password" placeholder="Enter your password" required>
                        <i class="fas fa-lock"></i>
                    </div>
                </div>
                
                <button type="submit" class="login-btn">
                    <i class="fas fa-sign-in-alt" style="margin-right: 10px;"></i>
                    Login
                </button>
                
                <a href="#" class="forgot-password" onclick="handleForgotPassword(event)">Forgot Password?</a>
                
                <!-- Demo Credentials -->
                <div class="demo-credentials">
                    <p class="demo-title">Customer Login Information:</p>
                    <div class="credential-list">
                        <div class="credential-item">
                            <span class="cred-user">customer</span> / <span class="cred-pass">customer123</span>
                            <small>→ Home Page</small>
                        </div>
                        <div class="credential-item">
                            <span class="cred-user">vip</span> / <span class="cred-pass">vip123</span>
                            <small>→ Collection</small>
                        </div>
                        <div class="credential-item">
                            <span class="cred-user">premium</span> / <span class="cred-pass">premium123</span>
                            <small>→ Collection</small>
                        </div>
                        <div class="credential-item">
                            <span class="cred-user">demo</span> / <span class="cred-pass">demo123</span>
                            <small>→ Home Page</small>
                        </div>
                    </div>
                    <p class="register-note" style="color: rgba(255,255,255,0.6); font-size: 0.75rem; margin-top: 10px; text-align: center; font-style: italic;">
                        💡 Or register as a new user below with your own credentials
                    </p>
                </div>
                
                <!-- New User Registration Link -->
                <div class="new-user-section">
                    <p class="new-user-text">New User? 
                        <a href="#" class="register-link" onclick="showRegistrationForm()">
                            Register Here
                        </a>
                    </p>
                </div>
            </form>
            
            <!-- Registration Form (Hidden by default) -->
            <form id="registerForm" class="auth-form" onsubmit="handleRegister(event)" style="display: none;">
                <div class="form-group">
                    <label for="reg_name">Full Name</label>
                    <div class="input-wrapper">
                        <input type="text" id="reg_name" name="reg_name" placeholder="Enter your full name" required>
                        <i class="fas fa-user"></i>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="reg_mobile">Mobile Number</label>
                    <div class="input-wrapper">
                        <input type="tel" id="reg_mobile" name="reg_mobile" placeholder="Enter your mobile number" maxlength="10" required>
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="reg_username">Username</label>
                    <div class="input-wrapper">
                        <input type="text" id="reg_username" name="reg_username" placeholder="Choose a username" required>
                        <i class="fas fa-user-tag"></i>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="reg_password">Password</label>
                    <div class="input-wrapper">
                        <input type="password" id="reg_password" name="reg_password" placeholder="Create a password" required>
                        <i class="fas fa-lock"></i>
                    </div>
                </div>
                
                <button type="submit" class="register-btn">
                    <i class="fas fa-user-plus" style="margin-right: 10px;"></i>
                    Create Account
                </button>
                
                <!-- Back to Login Link -->
                <div class="back-to-login">
                    <p class="back-text">Already have an account? 
                        <a href="#" class="back-link" onclick="hideRegistrationForm()">
                            Back to Login
                        </a>
                    </p>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        function showRegistrationForm() {
            // Hide login form and show registration form
            document.getElementById('loginForm').style.display = 'none';
            document.getElementById('registerForm').style.display = 'block';
            
            // Clear any messages
            hideMessage();
        }
        
        function hideRegistrationForm() {
            // Hide registration form and show login form
            document.getElementById('registerForm').style.display = 'none';
            document.getElementById('loginForm').style.display = 'block';
            
            // Clear any messages
            hideMessage();
        }
        
        function switchTab(tab) {
            // Remove active class from all tabs and forms
            document.querySelectorAll('.tab-btn').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.auth-form').forEach(f => f.classList.remove('active'));
            
            // Add active class to selected tab and form
            if (tab === 'login') {
                document.getElementById('loginTab').classList.add('active');
                document.getElementById('loginForm').classList.add('active');
            } else {
                document.getElementById('registerTab').classList.add('active');
                document.getElementById('registerForm').classList.add('active');
            }
            
            // Clear messages
            hideMessage();
        }
        
        function handleLogin(event) {
            event.preventDefault();
            
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            
            // Get registered users from localStorage
            const registeredUsers = JSON.parse(localStorage.getItem('victnowUsers') || '[]');
            
            // Check if user is in registered users
            const registeredUser = registeredUsers.find(user => 
                user.username === username && user.password === password
            );
            
            if (registeredUser) {
                showMessage(`Welcome back, ${registeredUser.name}! Redirecting to your account...`, 'success');
                
                // Store current user session
                localStorage.setItem('currentUser', JSON.stringify(registeredUser));
                
                setTimeout(() => {
                    window.location.href = '/account/';
                }, 2000);
                return;
            }
            
            // Check predefined customer accounts
            const predefinedUsers = {
                'customer': { password: 'customer123', name: 'Customer', redirect: '/' },
                'vip': { password: 'vip123', name: 'VIP Customer', redirect: '/collection/' },
                'premium': { password: 'premium123', name: 'Premium Customer', redirect: '/collection/' },
                'demo': { password: 'demo123', name: 'Demo User', redirect: '/' }
            };
            
            const user = predefinedUsers[username];
            
            if (user && user.password === password) {
                showMessage(`Welcome ${user.name}! Redirecting...`, 'success');
                
                // Store current user session
                localStorage.setItem('currentUser', JSON.stringify({
                    username: username,
                    name: user.name,
                    type: 'predefined'
                }));
                
                setTimeout(() => {
                    window.location.href = user.redirect;
                }, 2000);
            } else {
                showMessage('Invalid username or password. Please try again or register as a new user.', 'error');
                document.getElementById('password').value = '';
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
            }
        }
        
        function handleRegister(event) {
            event.preventDefault();
            
            const name = document.getElementById('reg_name').value;
            const mobile = document.getElementById('reg_mobile').value;
            const username = document.getElementById('reg_username').value;
            const password = document.getElementById('reg_password').value;
            
            // Validation
            if (name.length < 3) {
                showMessage('Please enter a valid name (at least 3 characters).', 'error');
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
                return;
            }
            
            if (mobile.length !== 10 || !/^\d+$/.test(mobile)) {
                showMessage('Please enter a valid 10-digit mobile number.', 'error');
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
                return;
            }
            
            if (username.length < 3) {
                showMessage('Username must be at least 3 characters long.', 'error');
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
                return;
            }
            
            if (password.length < 6) {
                showMessage('Password must be at least 6 characters long.', 'error');
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
                return;
            }
            
            // Get existing users from localStorage
            const existingUsers = JSON.parse(localStorage.getItem('victnowUsers') || '[]');
            
            // Check if username already exists
            if (existingUsers.find(user => user.username === username)) {
                showMessage('Username already exists. Please choose a different username.', 'error');
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
                return;
            }
            
            // Check if mobile number already exists
            if (existingUsers.find(user => user.mobile === mobile)) {
                showMessage('Mobile number already registered. Please use a different number.', 'error');
                
                setTimeout(() => {
                    hideMessage();
                }, 3000);
                return;
            }
            
            // Create new user object
            const newUser = {
                name: name,
                mobile: mobile,
                username: username,
                password: password,
                registrationDate: new Date().toISOString(),
                type: 'registered'
            };
            
            // Save user to localStorage
            existingUsers.push(newUser);
            localStorage.setItem('victnowUsers', JSON.stringify(existingUsers));
            
            console.log('New User Registered:', newUser);
            showMessage(`Account created successfully, ${name}! You can now login with your credentials.`, 'success');
            
            // Clear form
            document.getElementById('registerForm').reset();
            
            // Switch back to login form after 3 seconds
            setTimeout(() => {
                hideRegistrationForm();
                hideMessage();
            }, 3000);
        }
        
        function handleForgotPassword(event) {
            event.preventDefault();
            showMessage('Password reset link has been sent to your email address.', 'success');
            
            setTimeout(() => {
                hideMessage();
            }, 3000);
        }
        
        function showMessage(text, type) {
            const message = document.getElementById('message');
            message.textContent = text;
            message.className = 'message ' + type + ' show';
        }
        
        function hideMessage() {
            const message = document.getElementById('message');
            message.classList.remove('show');
        }
        
        // Add input focus effects
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('input');
            
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.parentElement.parentElement.style.transform = 'scale(1.02)';
                });
                
                input.addEventListener('blur', function() {
                    this.parentElement.parentElement.style.transform = 'scale(1)';
                });
            });
        });
    </script>
</body>
</html>
